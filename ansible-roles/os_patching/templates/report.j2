<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Linux Patch Report</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #f9f9f9;
            margin: 20px;
        }
        h1 {
            text-align: center;
            color: #2c3e50;
        }
        .summary {
            margin-bottom: 20px;
            text-align: center;
        }
        .summary div {
            display: inline-block;
            margin: 0 15px;
            padding: 10px 20px;
            border-radius: 6px;
            font-weight: bold;
            color: white;
        }
        .total { background-color: #3498db; }
        .updated { background-color: #2ecc71; }
        .rebooted { background-color: #f39c12; }
        .failed { background-color: #e74c3c; }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 10px;
        }
        th, td {
            border: 1px solid #ddd;
            padding: 8px;
            text-align: center;
        }
        th {
            background-color: #34495e;
            color: white;
        }
        td.ok {
            color: #2ecc71;
            font-weight: bold;
        }
        td.fail {
            color: #e74c3c;
            font-weight: bold;
        }
        .footer {
            margin-top: 20px;
            text-align: center;
            color: #888;
        }
    </style>
</head>
<body>

<h1>🚀 Linux Patch Report</h1>

{% set total = patch_results_summary | length %}
{% set updated_count = patch_results_summary | selectattr('updated') | list | length %}
{% set reboot_count = patch_results_summary | selectattr('reboot') | list | length %}
{% set failed_count = patch_results_summary | selectattr('status','equalto','FAILED') | list | length %}

<div class="summary">
    <div class="total">Total: {{ total }}</div>
    <div class="updated">Updated: {{ updated_count }}</div>
    <div class="rebooted">Rebooted: {{ reboot_count }}</div>
    <div class="failed">Failed: {{ failed_count }}</div>
</div>

<table>
    <tr>
        <th>Host</th>
        <th>OS</th>
        <th>Old Kernel</th>
        <th>New Kernel</th>
        <th>Packages Updated</th>
        <th>Reboot</th>
        <th>Status</th>
    </tr>

    {% for host in patch_results_summary %}
    <tr>
        <td>{{ host.host }}</td>
        <td>{{ host.os | default('N/A') }}</td>
        <td>{{ host.old_kernel }}</td>
        <td>{{ host.new_kernel }}</td>
        <td>{{ host.updated | ternary('Yes','No') }}</td>
        <td>{{ host.reboot | ternary('Yes','No') }}</td>
        <td class="{% if host.status | trim == 'SUCCESS' %}ok{% else %}fail{% endif %}">{{ host.status | trim }}</td>
    </tr>
    {% endfor %}
</table>

<div class="footer">
    Generated on {{ lookup('pipe', 'date') }}
</div>

</body>
</html>
