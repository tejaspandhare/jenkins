<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Linux Patch Report</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #f4f6f8;
            margin: 20px;
        }

        h1 {
            text-align: center;
            color: #2c3e50;
        }

        .summary {
            margin-bottom: 20px;
            text-align: center;
            font-size: 18px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            background: white;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

        th, td {
            padding: 12px;
            border: 1px solid #ddd;
            text-align: center;
        }

        th {
            background-color: #34495e;
            color: white;
        }

        td.ok {
            color: #2ecc71;
            font-weight: bold;
        }

        td.fail {
            color: #e74c3c;
            font-weight: bold;
        }

        .footer {
            margin-top: 20px;
            text-align: center;
            color: #888;
        }
    </style>
</head>
<body>

<h1>🚀 Linux Patch Report</h1>

<div class="summary">
    Total Hosts: {{ patch_results_summary | length }} |
    Success: {{ patch_results_summary | selectattr('status','equalto','SUCCESS') | list | length }} |
    Failed: {{ patch_results_summary | selectattr('status','equalto','FAILED') | list | length }}
</div>

<table>
    <tr>
        <th>Host</th>
        <th>OS</th>
        <th>Old Kernel</th>
        <th>New Kernel</th>
        <th>Updated</th>
        <th>Reboot</th>
        <th>Status</th>
    </tr>
    {% for host in patch_results_summary %}
    <tr>
        <td>{{ host.host }}</td>
        <td>{{ host.os | default('N/A') }}</td>
        <td>{{ host.old_kernel }}</td>
        <td>{{ host.new_kernel }}</td>
        <td>{{ 'Yes' if host.updated else 'No' }}</td>
        <td>{{ 'Yes' if host.reboot else 'No' }}</td>
        <td class="{% if host.status == 'SUCCESS' %}ok{% else %}fail{% endif %}">{{ host.status }}</td>
    </tr>
    {% endfor %}
</table>

<div class="footer">
    Generated by Ansible | {{ lookup('pipe','date') }}
</div>

</body>
</html>
