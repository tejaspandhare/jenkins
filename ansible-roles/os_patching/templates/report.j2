<!DOCTYPE html>
<html>
<head>
    <title>Linux Patch Report</title>
    <style>
        body { font-family: Arial, sans-serif; }
        h2 { color: #2e6c80; }
        table { border-collapse: collapse; width: 100%; }
        th { background-color: #4CAF50; color: white; padding: 8px; }
        td { padding: 8px; text-align: center; }
        tr:nth-child(even) { background-color: #f2f2f2; }
        .ok { color: green; font-weight: bold; }
        .warn { color: orange; font-weight: bold; }
        .fail { color: red; font-weight: bold; }
    </style>
</head>
<body>

<h2>Linux Patch Report</h2>

<table border="1">
<tr>
    <th>Host</th>
    <th>OS</th>
    <th>Old Kernel</th>
    <th>New Kernel</th>
    <th>Packages Updated</th>
    <th>Reboot Performed</th>
    <th>Status</th>
</tr>

{% for r in patch_results_summary %}
<tr>
    <td>{{ r.host | default('N/A') }}</td>
    <td>{{ r.os | default('N/A') }}</td>
    <td>{{ r.old_kernel | default('N/A') }}</td>
    <td>{{ r.new_kernel | default('N/A') }}</td>
    <td>{% if r.updated | default(false) %}Yes{% else %}No{% endif %}</td>
    <td>{% if r.reboot | default(false) %}Yes{% else %}No{% endif %}</td>
    <td>
        {% if r.status is defined and r.status == 'FAILED' %}
            <span class="fail">FAILED</span>
        {% elif r.reboot | default(false) %}
            <span class="warn">REBOOTED</span>
        {% elif r.updated | default(false) %}
            <span class="ok">UPDATED</span>
        {% else %}
            <span class="ok">NO CHANGE</span>
        {% endif %}
    </td>
</tr>
{% endfor %}

</table>
</body>
</html>
