<html>
<head>
<title>Patch Report</title>
</head>

<body>

<h2>Linux Patch Report</h2>

<table border="1">
<tr>
<th>Host</th>
<th>OS</th>
<th>Old Kernel</th>
<th>New Kernel</th>
<th>Packages Updated</th>
<th>Reboot Performed</th>
</tr>

{% for r in results %}
<tr>
<td>{{ r.host }}</td>
<td>{{ r.os }}</td>
<td>{{ r.old_kernel }}</td>
<td>{{ r.new_kernel }}</td>
<td>{{ r.updated }}</td>
<td>{{ r.reboot }}</td>
</tr>
{% endfor %}

</table>

</body>
</html>
