<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Linux Patch Report</title>
    <style>
        body { font-family: Arial; margin:20px; background:#f4f6f8;}
        h1 { text-align:center; color:#2c3e50;}
        table { width:100%; border-collapse: collapse; background:white; box-shadow:0 2px 5px rgba(0,0,0,0.1);}
        th, td { border:1px solid #ddd; padding:8px; text-align:center;}
        th { background:#34495e; color:white; }
        td.ok { color:#2ecc71; font-weight:bold; }
        td.fail { color:#e74c3c; font-weight:bold; }
        .summary { text-align:center; margin-bottom:15px; }
        .footer { text-align:center; margin-top:15px; color:#888; }
    </style>
</head>
<body>

<h1>🚀 Linux Patch Report</h1>

{% set total = patch_results_summary | length %}
{% set success = patch_results_summary | selectattr('status','equalto','SUCCESS') | list | length %}
{% set failed = total - success %}

<div class="summary">
    <strong>Total Hosts:</strong> {{ total }} | 
    <strong>Success:</strong> {{ success }} | 
    <strong>Failed:</strong> {{ failed }}
</div>

<table>
    <tr>
        <th>Host</th>
        <th>OS</th>
        <th>Old Kernel</th>
        <th>New Kernel</th>
        <th>Updated</th>
        <th>Reboot</th>
        <th>Status</th>
    </tr>
    {% for host in patch_results_summary %}
    <tr>
        <td>{{ host.host }}</td>
        <td>{{ host.os }}</td>
        <td>{{ host.old_kernel }}</td>
        <td>{{ host.new_kernel }}</td>
        <td>{{ 'Yes' if host.updated else 'No' }}</td>
        <td>{{ 'Yes' if host.reboot else 'No' }}</td>
        <td class="{% if host.status=='SUCCESS' %}ok{% else %}fail{% endif %}">{{ host.status }}</td>
    </tr>
    {% endfor %}
</table>

<div class="footer">
    Generated by Ansible | {{ lookup('pipe','date') }}
</div>

</body>
</html>
