<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Patching Report</title>

    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #f4f6f8;
            margin: 20px;
        }

        h1 {
            text-align: center;
            color: #2c3e50;
        }

        .summary {
            display: flex;
            justify-content: center;
            margin-bottom: 20px;
        }

        .card {
            padding: 15px 25px;
            margin: 10px;
            border-radius: 8px;
            color: white;
            font-size: 18px;
            font-weight: bold;
        }

        .total   { background-color: #3498db; }
        .success { background-color: #2ecc71; }
        .failed  { background-color: #e74c3c; }

        table {
            width: 100%;
            border-collapse: collapse;
            background: white;
            font-family: monospace;
        }

        th {
            background-color: #34495e;
            color: white;
            padding: 10px;
        }

        td {
            padding: 10px;
            text-align: center;
            border-bottom: 1px solid #ddd;
        }

        .ok   { color: #2ecc71; font-weight: bold; }
        .fail { color: #e74c3c; font-weight: bold; }

        .footer {
            margin-top: 20px;
            text-align: center;
            color: #888;
        }
    </style>
</head>

<body>

<h1>🚀 Patch Report</h1>

{% set total = patch_results_summary | length %}
{% set success = patch_results_summary | selectattr('status','search','SUCCESS') | list | length %}
{% set failed = total - success %}

<div class="summary">
    <div class="card total">Total: {{ total }}</div>
    <div class="card success">Success: {{ success }}</div>
    <div class="card failed">Failed: {{ failed }}</div>
</div>

<table>
    <tr>
        <th>Host</th>
        <th>OS</th>
        <th>Kernel</th>
        <th>Updated</th>
        <th>Reboot</th>
        <th>Status</th>
    </tr>

    {% for h in patch_results_summary %}
    <tr>
        <td>{{ h.host }}</td>
        <td>{{ h.os | default('N/A') }}</td>
        <td>{{ h.old_kernel }} → {{ h.new_kernel }}</td>
        <td>{{ h.updated }}</td>
        <td>{{ h.reboot }}</td>
        <td class="{% if h.status | trim == 'SUCCESS' %}ok{% else %}fail{% endif %}">
            {{ h.status | trim }}
        </td>
    </tr>
    {% endfor %}
</table>

<div class="footer">
    Generated by Ansible | {{ lookup('pipe', 'date "+%Y-%m-%d %H:%M:%S"') }}
</div>

</body>
</html>
