pipeline {
    agent any

    options {
        timestamps()
        ansiColor('xterm')
        buildDiscarder(logRotator(numToKeepStr: '20'))
    }

    environment {
        ANSIBLE_FORCE_COLOR = 'true'
    }

    parameters {
        string(
            name: 'SERVER_NAME',
            defaultValue: '',
            description: 'Target server(s) separated by ; e.g. lb1;lb2;kmaster1'
        )
    }

    stages {

        stage('Checkout Repository') {
            steps {
                checkout scm
            }
        }

        stage('Run Enterprise Audit') {
            steps {
                withCredentials([
                    file(credentialsId: 'automation-key', variable: 'ANSIBLE_KEY_FILE')
                ]) {
                    script {
                        def rc = sh(
                            script: """
                                echo "Running Ansible Audit on: ${params.SERVER_NAME}"

                                ansible-playbook \
                                    -i inventory/hosts \
                                    playbooks/auditreport2.yml \
                                    --private-key="\$ANSIBLE_KEY_FILE" \
                                    -e "hosts=${params.SERVER_NAME}"
                            """,
                            returnStatus: true
                        )

                        echo "Ansible Exit Code: ${rc}"

                        if (rc == 0 || rc == 2) {
                            echo "Ansible completed successfully."
                        } else {
                            error("Ansible failed with exit code ${rc}")
                        }
                    }
                }
            }
        }

        stage('Verify Generated Reports') {
            steps {
                sh '''
                    echo "Listing generated reports:"
                    ls -lah *.html *.txt *.csv 2>/dev/null || true
                '''
            }
        }
    }

    post {
        always {
            echo "Build completed."
        }

        success {
            echo "Audit completed successfully."
        }

        failure {
            echo "Audit failed."
        }
    }
}
