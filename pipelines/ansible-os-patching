pipeline {
    agent any

    environment {
        ANSIBLE_STDOUT_CALLBACK = 'minimal'
        ANSIBLE_DISPLAY_SKIPPED_HOSTS = 'false'
        ANSIBLE_FORCE_COLOR = 'false'
    }

    options {
        timestamps()
    }

    stages {

        stage('Clean Workspace') {
            steps {
                cleanWs()
            }
        }

        stage('Checkout Code') {
            steps {
                checkout scm
            }
        }

        stage('OS Maintenance & Kernel Check') {
            steps {
                sshagent(['automation-key']) {
                    sh '''
                    ansible-playbook \
                      -i inventory/hosts \
                      playbooks/ubuntu_os_update2.yaml \
                      -e "hosts=${SERVER_NAME}"
                    '''
                }
            }
        }
    }

    post {
        success {
            echo "OS patching completed successfully."
        }
        failure {
            echo "OS patching failed."
        }
    }
}
