pipeline {
    agent any

    parameters {
        string(
            name: 'SERVER_NAME',
            defaultValue: '',
            description: 'List of hosts separated by ;  (example: server1;server2)'
        )
    }

    environment {
        ANSIBLE_FORCE_COLOR = 'true'
    }

    stages {

        stage('Run OS Patching') {
            steps {

                withCredentials([file(credentialsId: 'automation-key', variable: 'ANSIBLE_KEY_FILE')]) {

                    script {

                        // convert ; → ,
                        def hosts = params.SERVER_NAME.replace(";", ",")

                        sh """
                        ansible-playbook \
                          -i inventory/hosts \
                          ansible-roles/os_patching/patch.yml \
                          --private-key=${ANSIBLE_KEY_FILE} \
                          -e "hosts=${hosts}"
                        """

                    }
                }
            }
        }
    }
}
