pipeline {
    agent any

    environment {
        ANSIBLE_FORCE_COLOR = 'true'
    }

    parameters {
        string(
            name: 'WORKING_HOST',
            defaultValue: 'lb1',
            description: 'Working Host'
        )

        string(
            name: 'NONWORKING_HOST',
            defaultValue: 'lb2',
            description: 'Non-working Host'
        )
    }

    stages {

        stage('Clean Workspace') {
            steps {
                cleanWs()
            }
        }

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Compare Packages') {
            steps {
                withCredentials([
                    file(credentialsId: 'automation-key', variable: 'ANSIBLE_KEY_FILE')
                ]) {
                    sh '''
                        ansible-playbook \
                          -i inventory/hosts \
                          playbooks/compare_packages.yaml \
                          --private-key="$ANSIBLE_KEY_FILE" \
                          -e "working_host=${WORKING_HOST}" \
                          -e "nonworking_host=${NONWORKING_HOST}"
                    '''
                }
            }
        }

        stage('Verify Reports') {
            steps {
                sh '''
                    echo "Current Workspace:"
                    pwd

                    echo ""
                    echo "Generated Reports:"
                    ls -l reports || true

                    echo ""
                    echo "All HTML Files:"
                    find . -name "*.html"

                    echo ""
                    echo "All TXT Files:"
                    find . -name "*.txt"
                '''
            }
        }
    }

    post {
        always {

            archiveArtifacts(
                artifacts: 'reports/*',
                fingerprint: true,
                allowEmptyArchive: true
            )

            script {
                if (fileExists('reports/missing_packages.html')) {

                    publishHTML(target: [
                        reportDir: 'reports',
                        reportFiles: 'missing_packages.html',
                        reportName: 'Package Comparison Report',
                        keepAll: true,
                        alwaysLinkToLastBuild: true,
                        allowMissing: false
                    ])

                } else {
                    echo "HTML report not found. Skipping publishHTML."
                }
            }
        }

        success {
            echo "Package comparison completed successfully."
        }

        failure {
            echo "Package comparison failed."
        }
    }
}
