pipeline {
    agent any

    environment {
        ANSIBLE_FORCE_COLOR = 'true'
    }

    stages {
        stage('Cleanup Junk data') {
            steps {
                withCredentials([file(credentialsId: 'automation-key', variable: 'ANSIBLE_KEY_FILE')]) {
                    script {
                        sh """
                            ansible-playbook \
                                -i inventory/hosts \
                                playbooks/compare_packages.yam \
                                --private-key="$ANSIBLE_KEY_FILE" \
                                -e "working_host=${params.WORKING_HOST}" \
                                -e "nonworking_host=${params.NONWORKING_HOST}"
                        """
                    }
                }
            }
        }
    }
}
