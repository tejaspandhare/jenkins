pipeline {
    agent any

    environment {
        ANSIBLE_FORCE_COLOR = 'true'
    }

    parameters {
        string(
            name: 'WORKING_HOST',
            defaultValue: '',
            description: 'Working Host'
        )
        string(
            name: 'NONWORKING_HOST',
            defaultValue: '',
            description: 'Non-working Host'
        )
    }

    stages {

        stage('Clean Workspace') {
            steps {
                cleanWs()
            }
        }

        stage('Compare Installed Packages') {
            steps {
                withCredentials([
                    file(credentialsId: 'automation-key', variable: 'ANSIBLE_KEY_FILE')
                ]) {

                    sh '''
                        pwd
                        ls -la

                        ansible-playbook \
                          -i inventory/hosts \
                          playbooks/compare_packages.yaml \
                          --private-key="$ANSIBLE_KEY_FILE" \
                          -e "working_host=${WORKING_HOST}" \
                          -e "nonworking_host=${NONWORKING_HOST}"
                    '''
                }
            }
        }

        stage('Verify Reports') {
            steps {
                sh '''
                    echo "===== Current Directory ====="
                    pwd

                    echo "===== Workspace ====="
                    ls -la

                    echo "===== Reports ====="
                    find . -type f | grep -E "missing_packages|reports|html|txt" || true
                '''
            }
        }
    }

    post {
        always {

            archiveArtifacts(
                artifacts: '**/reports/*',
                fingerprint: true,
                allowEmptyArchive: true
            )

            publishHTML(target: [
                reportDir: 'reports',
                reportFiles: 'missing_packages.html',
                reportName: 'Package Comparison Report',
                keepAll: true,
                alwaysLinkToLastBuild: true,
                allowMissing: true
            ])
        }

        success {
            echo 'Package comparison completed successfully.'
        }

        failure {
            echo 'Package comparison failed.'
        }
    }
}
